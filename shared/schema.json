{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://slaicer/schema.json",
  "title": "Slaicer Project",
  "type": "object",
  "required": ["version", "image", "width", "height", "rows"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": 1 },
    "image": { "type": "string", "minLength": 1 },
    "width": { "type": "integer", "minimum": 1 },
    "height": { "type": "integer", "minimum": 1 },
    "rules": { "type": "object" },
    "email": {
      "type": "object",
      "properties": {
        "subject": { "type": ["string", "null"] },
        "preview": { "type": ["string", "null"] },
        "preheader": { "type": ["string", "null"] },
        "config": { "type": ["string", "null"] }
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "top", "bottom", "columns"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "top": { "type": "integer", "minimum": 0 },
          "bottom": { "type": "integer", "minimum": 1 },
          "layout": { "type": "string" },
          "locked": { "type": "boolean" },
          "columns": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "left", "right"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "left": { "type": "integer", "minimum": 0 },
                "right": { "type": "integer", "minimum": 1 },
                "name": { "type": ["string", "null"] },
                "link": { "type": ["string", "null"] },
                "alt": { "type": ["string", "null"] },
                "include": { "type": "boolean" }
              }
            }
          }
        }
      }
    }
  }
}
